- const PATH = pathPrefix;
- const lang = 'ru';
- const blocks = {}

mixin placeholderPath(path=PATH)
    -
        staticPath = {
            css: `${path}assets/css`,
            js: `${path}assets/js`,
            img: `${path}assets/img/content`,
        }

mixin set(key)
    - blocks[key] = this.block

+placeholderPath()